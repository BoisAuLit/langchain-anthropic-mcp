        <UserObject label="&lt;div style=&quot;color: #d4d4d4;background-color: #1e1e1e;font-family: &#39;Operator Mono Lig&#39;, Menlo, Monaco, &#39;Courier New&#39;, monospace;font-weight: 500;font-size: 14px;line-height: 21px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;def&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #dcdcaa;&quot;&gt;best_joke&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;state&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;: OverallState):&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    jokes = &lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;&lt;/span&gt;&lt;span style=&quot;color: #d7ba7d;&quot;&gt;\n\n&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;.join(state[&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;jokes&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;])&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    prompt = best_joke_prompt.format(&lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;topic&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=state[&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;topic&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;], &lt;/span&gt;&lt;span style=&quot;color: #9cdcfe;&quot;&gt;jokes&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;=jokes)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    response = model.with_structured_output(BestJoke).invoke(prompt)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; {&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;best_selected_joke&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;: state[&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;jokes&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;][response.id]}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" id="bgFHZMIFmcvsHs2evzA_-11">
