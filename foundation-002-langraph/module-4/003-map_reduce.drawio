d4d4d4;&quot;&gt;=state[&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;subject&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;])&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    response = model.with_structured_output(Joke).invoke(prompt)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;color: #c586c0;&quot;&gt;return&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt; {&lt;/span&gt;&lt;span style=&quot;color: #ce9178;&quot;&gt;&quot;jokes&quot;&lt;/span&gt;&lt;span style=&quot;color: #d4d4d4;&quot;&gt;: [response.joke]}&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" id="bgFHZMIFmcvsHs2evzA_-7">
