{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "../../../.."],
      "env": {
        "NPM_CONFIG_LOGLEVEL": "silent",
        "NODE_ENV": "production"
      }
    },
    "research": {
      "command": "uv",
      "args": ["run", "./research_server.py"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {
        "NPM_CONFIG_LOGLEVEL": "silent",
        "NODE_ENV": "production"
      }
    }
  }
}
